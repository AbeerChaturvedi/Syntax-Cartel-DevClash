# ═══════════════════════════════════════════════════════════
#  Project Velure — Environment Configuration
#  Real-Time Financial Crisis Early Warning System
# ═══════════════════════════════════════════════════════════

# ── Infrastructure ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=velure
POSTGRES_PASSWORD=velure_hackathon_2026
POSTGRES_DB=velure

# ── Data Mode ──────────────────────────────────────────────
# simulator | finnhub | hybrid | replay
DATA_MODE=simulator

# ── Live Data (optional) ──────────────────────────────────
FINNHUB_API_KEY=
POLYGON_API_KEY=

# ── Pipeline Tuning ────────────────────────────────────────
TICK_RATE=0.25
BATCH_SIZE=10
FLUSH_INTERVAL_MS=500
MAX_STREAM_LEN=10000

# ── ML Model Tuning ───────────────────────────────────────
IF_CONTAMINATION=0.05
IF_N_ESTIMATORS=200
LSTM_HIDDEN_DIM=64
LSTM_LATENT_DIM=32
LSTM_SEQ_LENGTH=60
CISS_WINDOW=500
VAR_WINDOW=500
VAR_CONFIDENCE=0.99

# ── Ensemble Weights ──────────────────────────────────────
# Must sum to 1.0
ENSEMBLE_IF_WEIGHT=0.35
ENSEMBLE_LSTM_WEIGHT=0.35
ENSEMBLE_CISS_WEIGHT=0.20
ENSEMBLE_COPULA_WEIGHT=0.10

# ── Alert Thresholds ──────────────────────────────────────
ALERT_THRESHOLD_HIGH=0.7
ALERT_THRESHOLD_CRITICAL=0.85

# ── API / Security ────────────────────────────────────────
CORS_ORIGINS=*
VELURE_API_KEY=
RATE_LIMIT_PER_MINUTE=120

# ── Speed Presets (internal, don't change) ────────────────
# slow=0.50s, normal=0.25s, fast=0.10s, turbo=0.04s

# ── v3: Alerting (all optional) ──────────────────────────
ALERT_SLACK_WEBHOOK=
ALERT_DISCORD_WEBHOOK=
ALERT_PAGERDUTY_KEY=
ALERT_GENERIC_WEBHOOK=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SMTP_USER=
ALERT_EMAIL_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_DEDUP_WINDOW_SEC=300
ALERT_MIN_SEVERITY=HIGH

# ── v3: Model Persistence ────────────────────────────────
MODEL_CHECKPOINT_DIR=./data/checkpoints
MODEL_CHECKPOINT_ON_CRISIS=1
MODEL_CHECKPOINT_PERIODIC_SEC=300

# ── v3: Watermarking ─────────────────────────────────────
WATERMARK_LATENESS_MS=300

# ── v3: Replay ────────────────────────────────────────────
REPLAY_DATA_DIR=./data/historical
REPLAY_SPEED_MULTIPLIER=60.0

# ── v3: TimescaleDB (opt-in) ─────────────────────────────
USE_TIMESCALE=0

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
